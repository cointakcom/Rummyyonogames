# .htaccess file में यह code add करो (सबसे ऊपर)

# Force www और .com domain
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove .com extension if someone tries to access without it
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ https://rummyyonogames.com/$1 [R=301,L]
    
    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Remove trailing slash
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [R=301,L]
</IfModule>
